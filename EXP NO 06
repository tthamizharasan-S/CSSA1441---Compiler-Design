%{
#include <stdio.h>
%}

%option noyywrap

ID     [a-zA-Z_][a-zA-Z0-9_]*

%%

{ID}        { printf("%s -> VALID IDENTIFIER\n", yytext); }

[0-9]+      { printf("%s -> INVALID IDENTIFIER (starts with digit)\n", yytext); }

.           { printf("%s -> INVALID IDENTIFIER\n", yytext); }

%%

int main() {
    printf("Enter input (Ctrl+Z + Enter to stop):\n");
    yylex();
    return 0;
}
