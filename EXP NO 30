%{
#include <stdio.h>

int vowels = 0;
int consonants = 0;
%}

%%
[aeiouAEIOU]        { vowels++; }        /* Count vowels */
[a-zA-Z]            { consonants++; }    /* Count consonants */
\n                  ;                    /* Ignore newline */
.                   ;                    /* Ignore spaces, digits, symbols */
%%

int yywrap(void) {
    return 1;
}

int main(void) {
    printf("Enter a sentence:\n");
    yylex();

    printf("\nNumber of Vowels = %d\n", vowels);
    printf("Number of Consonants = %d\n", consonants);

    return 0;
}
